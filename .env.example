# PantryPal Core - Example Environment Variables
# Copy this file to ".env" and fill in real values. Do NOT commit your .env file.
# Security: Never share real secrets in screenshots/issues, and rotate any leaked keys immediately.

# Database (example placeholders)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=example
DB_USER=your_db_user
DB_PASS=your_db_password

# API keys (placeholders)
SPOONACULAR_API_KEY=your_spoonacular_key_here
API_NINJAS_KEY=your_api_ninjas_key_here
FDC_API_KEY=your_usda_fdc_key_here
SUGGESTIC_API_KEY=your_suggestic_api_token_here
# Suggestic requires an sg-user UUID header when using API Token auth
SUGGESTIC_USER_ID=your_suggestic_user_uuid_here
# Optional: If you already have a JWT for Suggestic, the provider will prefer it (no sg-user needed)
SUGGESTIC_JWT=your_suggestic_jwt_here
# Optional partner header if your account uses it
# SUGGESTIC_PARTNER=your_partner_slug

# Open Food Facts polite user agent (identify your app/email generically; do not expose personal email)
OFF_USER_AGENT="PantryPalCore/1.0 (+contact@example.com)"

# App
APP_ENV=local
APP_DEBUG=true
APP_URL=http://pantrypal.local

# Internal tools (disable in production)
INTERNAL_TOOLS_ENABLED=false

# Redis (optional but recommended for caching)
# If you have a full URL, you can set REDIS_URL (e.g., rediss://default:password@host:port/0)
# Otherwise set individual parts; for Redis Cloud, TLS is usually required and username is typically 'default'.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
# TLS verification (recommended true in production; set REDIS_CAFILE/REDIS_CAPATH if needed)
REDIS_VERIFY_PEER=false
REDIS_VERIFY_PEER_NAME=false
# REDIS_CAFILE=
# REDIS_CAPATH=
