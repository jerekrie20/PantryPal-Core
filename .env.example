# PantryPal Core - Example Environment Variables
# Copy this file to ".env" and fill in real values. Do NOT commit your .env file.
# Security: Never share real secrets in screenshots/issues, and rotate any leaked keys immediately.

# Database (example placeholders)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=example
DB_USER=your_db_user
DB_PASS=your_db_password

# API keys (placeholders)
FDC_API_KEY=your_usda_fdc_key_here

# Open Food Facts polite user agent (required — format: AppName/Version (ContactEmail))
# READ operations (search, barcode lookup) need only this header; no additional auth required.
OFF_USER_AGENT="PantryPalCore/1.0 (contact@example.com)"

# FatSecret Platform API (OAuth 2.0 client_credentials)
# Free tier: https://platform.fatsecret.com — create an app to get Client ID + Secret.
# Used for food search, food detail, recipe search, and recipe detail (24-hour cache only).
FATSECRET_CLIENT_ID=your_fatsecret_client_id_here
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret_here

# AI Cooking Assistant (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangCache (Semantic AI caching - Optional but recommended for cost savings)
# Get your API credentials from: https://www.langcache.ai
LANGCACHE_API_KEY=your_langcache_api_key
LANGCACHE_HOST=your_langcache_host
LANGCACHE_CACHE_ID=your_cache_id
LANGCACHE_ENABLED=false

# App
APP_ENV=local
APP_DEBUG=true
APP_URL=http://pantrypal.local

# Internal tools (disable in production)
INTERNAL_TOOLS_ENABLED=false

# Redis (optional but recommended for caching)
# If you have a full URL, you can set REDIS_URL (e.g., rediss://default:password@host:port/0)
# Otherwise set individual parts; for Redis Cloud, TLS is usually required and username is typically 'default'.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
# TLS verification (recommended true in production; set REDIS_CAFILE/REDIS_CAPATH if needed)
REDIS_VERIFY_PEER=false
REDIS_VERIFY_PEER_NAME=false
# REDIS_CAFILE=
# REDIS_CAPATH=
