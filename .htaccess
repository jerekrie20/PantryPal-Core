# Root-level Apache rules to route requests into the public/ directory
# Fixes 403 on homepage when the document root is the project root

Options -Indexes

RewriteEngine On
RewriteBase /

# --- Security: block sensitive files/directories BEFORE the serve-directly rules ---
# Dotfiles and env files (.env, .git, .htaccess itself is protected by Apache)
RewriteRule (^|/)\.(?!well-known/) - [F,L]
# Application internals — nothing outside public/ should be web-accessible
RewriteRule ^(app|src|tests|vendor|docs|storage|node_modules)(/|$) - [F,L]
# Project metadata
RewriteRule ^(composer\.(json|lock)|package(-lock)?\.json|vite\.config\..*)$ - [F,L]

# Serve existing files/directories directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Ensure default index points to public/index.php
DirectoryIndex public/index.php

# Send the bare root to public/
RewriteRule ^$ public/ [L]

# For all other requests not already under /public, route into /public
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]
