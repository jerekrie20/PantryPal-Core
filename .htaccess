# Forward everything to public/ unless the file/folder exists
RewriteEngine On
RewriteBase /

# If the requested path is a real file or folder here, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, forward into the app’s public/ directory
RewriteRule ^(.*)$ public/$1 [L]